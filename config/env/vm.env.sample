# Copy this file to .env.production (ignored) before deploying on a dedicated VM.
# Do not track secrets in the repo; override values via the target host's secret store.

ENV=production
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
API_HOST=0.0.0.0
API_PORT=8000
F1_API_BASE_URL=http://api:8000
STREAMLIT_SERVER_PORT=8501
